{
  "name": "mysite",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed-db.ts",
    "publish:services": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/publish-services.ts",
    "publish:portfolio": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/publish-portfolio.ts",
    "test:db": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/test-db-connection.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@maizzle/framework": "^5.3.1",
    "@payloadcms/admin-bar": "3.71.1",
    "@payloadcms/db-mongodb": "3.71.1",
    "@payloadcms/email-nodemailer": "3.71.1",
    "@payloadcms/live-preview-react": "3.71.1",
    "@payloadcms/next": "3.71.1",
    "@payloadcms/plugin-form-builder": "3.71.1",
    "@payloadcms/plugin-nested-docs": "3.71.1",
    "@payloadcms/plugin-redirects": "3.71.1",
    "@payloadcms/plugin-search": "3.71.1",
    "@payloadcms/plugin-seo": "3.71.1",
    "@payloadcms/richtext-lexical": "3.71.1",
    "@payloadcms/storage-s3": "3.71.1",
    "@payloadcms/ui": "3.71.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/nodemailer": "^7.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "gsap": "^3.14.2",
    "lenis": "^1.3.16",
    "lucide-react": "^0.378.0",
    "mongodb": "^7.0.0",
    "next": "15.4.10",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^7.0.12",
    "payload": "3.71.1",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "7.45.4",
    "sharp": "0.34.2",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "@tailwindcss/typography": "^0.5.13",
    "typescript": "5.7.3",
    "@types/react": "19.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.56.1",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.5.4",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react": "4.5.2",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.7",
    "jsdom": "26.1.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
