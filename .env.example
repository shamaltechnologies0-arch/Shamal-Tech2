# MongoDB (Payload CMS). Use Atlas in production / on Vercel.
# MONGODB_URI=mongodb://127.0.0.1:27017/shamal-payload
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# Optional alias:
# DATABASE_URI=mongodb+srv://...
MONGODB_URI=mongodb://127.0.0.1:27017/shamal-payload

# Never set in production unless you intend to wipe the CMS: allows destructive seed + /next/seed.
# ALLOW_DANGEROUS_SEED=true
# Rare: show the admin “Seed your database” button on production (still requires ALLOW_DANGEROUS_SEED to run).
# NEXT_PUBLIC_SHOW_ADMIN_SEED_BUTTON=true

# Local BSON dump (requires `mongodump` on PATH): pnpm backup:mongo
# Output: ./backup/mongo-dump-<UTC-time>/

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=https://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Optional: auth for /api/revalidate (cache clear). If unset, CRON_SECRET is used.
# REVALIDATE_SECRET=YOUR_REVALIDATE_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CONTACT_EMAIL=
CONTACT_PHONE=
# Site-wide maintenance: 503 for all pages + APIs, static HTML (no MongoDB via HTTP).
# Restart dev server after changing. If middleware still ignores it, set NEXT_PUBLIC_MAINTENANCE_MODE=true.
MAINTENANCE_MODE=false
# NEXT_PUBLIC_MAINTENANCE_MODE=false
# Retry-After header (seconds). Default 3600.
MAINTENANCE_RETRY_AFTER=3600
# Optional: WhatsApp number for maintenance CTAs (digits only, e.g. 971501234567). Falls back to digits from CONTACT_PHONE.
MAINTENANCE_WHATSAPP_NUMBER=
SEED_DATABASE=

# Employee QR Profile System
# Profile images and company PDFs use the Media collection (S3 when configured)
# No additional env vars required - uses NEXT_PUBLIC_SERVER_URL for profile URLs

# ClickUp API token (shared: sales pipeline + training lists below)
CLICKUP_API_TOKEN=
# ClickUp Sales Pipeline (website leads sync)
CLICKUP_LIST_ID=

# --- Shamal Training Platform (/training) ---
# Three ClickUp Lists: each task is a row; add custom fields to each list (names must match defaults or TRAINING_CLICKUP_FIELD_*).
TRAINING_CLICKUP_USERS_LIST_ID=
TRAINING_CLICKUP_PROGRESS_LIST_ID=
TRAINING_CLICKUP_PAYMENTS_LIST_ID=
# Optional: override custom field labels if yours differ from Email, Name, Role, Password_Hash, Warm_Lead, user_email, course_id, etc.
# TRAINING_CLICKUP_FIELD_EMAIL=
# TRAINING_CLICKUP_FIELD_NAME=
# TRAINING_CLICKUP_FIELD_PAYMENT_CREATED=created_at
# JWT for training sessions (separate from Payload)
TRAINING_JWT_SECRET=
# Stripe (Checkout + webhook at /api/training/webhooks/stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
# Vimeo API token for resolving private embed URLs (optional; public fallback if unset)
VIMEO_ACCESS_TOKEN=