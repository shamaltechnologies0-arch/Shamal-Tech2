# Database connection string (Payload uses MONGODB_URI)
MONGODB_URI=mongodb://127.0.0.1/your-database-name

# For MongoDB Atlas + Vercel (M0 free tier), add pool limits to avoid connection exhaustion:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?maxPoolSize=5&minPoolSize=0&maxIdleTimeMS=60000

# Legacy (if used elsewhere)
# DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
NEWSLETTER_API_KEY= 
NEWSLETTER_AUDIENCE_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CONTACT_EMAIL=
CONTACT_PHONE=
SEED_DATABASE=